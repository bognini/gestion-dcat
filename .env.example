# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/gestion_dcat?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=gestion_dcat

# Authentication
AUTH_SECRET=your_super_secret_key_change_this_in_production

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@dcat.ci

# Application
NEXT_PUBLIC_APP_URL=https://gestion.dcat.ci
NODE_ENV=development

# Sécurité — à activer en production après le premier déploiement
SETUP_DISABLED=true           # Désactive /api/auth/setup (mettre true en prod)
CLEANUP_SECRET=your_cleanup_secret_change_this  # Secret pour /api/internal/cleanup
